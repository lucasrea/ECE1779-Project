OPENAI_API_KEY=ENTER_OPENAI_API_HERE
ANTHROPIC_API_KEY=ENTER_ANTHROPIC_API_HERE
GEMINI_API_KEY=ENTER_GOOGLE_API_HERE
API_KEY_PEPPER=ENTER_GATEWAY_API_KEY_PEPPER_HERE
DIGITALOCEAN_API_KEY=ENTER_DIGITALOCEAN_API_HERE
CLUSTER_ID=ENTER_CLUSTER_ID_HERE
POD_NAME=ENTER_POD_NAME_HERE

# Database (not needed if using docker-compose — set automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/gateway

# Semantic cache
CACHE_SIMILARITY_THRESHOLD=0.95
EMBEDDING_MODEL=all-MiniLM-L6-v2

LITELLM_PRICING_JSON_URL=https://raw.githubusercontent.com/BerriAI/liteLLM/main/model_prices_and_context_window.json
